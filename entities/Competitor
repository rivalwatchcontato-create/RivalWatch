{
  "name": "Competitor",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do concorrente"
    },
    "url": {
      "type": "string",
      "description": "URL do produto do concorrente"
    },
    "product_name": {
      "type": "string",
      "description": "Nome do produto monitorado"
    },
    "current_price": {
      "type": "number",
      "description": "Pre\u00e7o atual do produto"
    },
    "previous_price": {
      "type": "number",
      "description": "Pre\u00e7o anterior do produto"
    },
    "currency": {
      "type": "string",
      "enum": [
        "BRL",
        "USD",
        "EUR"
      ],
      "default": "BRL",
      "description": "Moeda do pre\u00e7o"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "error"
      ],
      "default": "active",
      "description": "Status do monitoramento"
    },
    "last_checked": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltima verifica\u00e7\u00e3o de pre\u00e7o"
    },
    "price_change_percent": {
      "type": "number",
      "description": "Percentual de mudan\u00e7a do pre\u00e7o"
    },
    "category": {
      "type": "string",
      "description": "Categoria do produto"
    },
    "notes": {
      "type": "string",
      "description": "Notas sobre o concorrente"
    },
    "logo_url": {
      "type": "string",
      "description": "URL do logo do concorrente"
    }
  },
  "required": [
    "name",
    "url",
    "product_name"
  ]
}